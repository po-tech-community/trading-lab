# Copy this file to .env.production and fill in every value before deploying.
# NEVER commit .env.production to git.
#
# Start the stack:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build
#
# The --env-file flag serves two purposes:
#   1. Supplies ${REDIS_PASSWORD} substitution used inside docker-compose.prod.yml.
#   2. Injects all vars into the backend container via env_file: .env.production.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
# Allow requests from your production frontend domain (no trailing slash).
FRONTEND_ORIGIN=https://your-frontend-domain.com

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Use the Docker service name "mongodb" as the host inside the compose network.
MONGODB_URI=mongodb://mongodb:27017/trading-lab

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
# Also used by the redis service in docker-compose.prod.yml via ${REDIS_PASSWORD}.
REDIS_PASSWORD=change-me-to-a-strong-random-password
REDIS_TTL_MS=60000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# These two values MUST be different.
JWT_SECRET=change-me-generate-with-crypto-randomBytes-64
JWT_REFRESH_SECRET=change-me-to-a-DIFFERENT-long-random-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_MAX_AGE=604800000

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-backend-domain.com/api/v1/auth/google/callback
FRONTEND_GOOGLE_CALLBACK_URL=https://your-frontend-domain.com/auth/google/callback

# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
AI_RATE_LIMIT_MAX=5
AI_RATE_LIMIT_WINDOW_MS=60000

# ── MCP (optional) ────────────────────────────────────────────────────────────
MCP_ENABLED=false
MCP_PROVIDERS=[]
MCP_TIMEOUT_MS=8000
MCP_RETRY_ATTEMPTS=2
MCP_FALLBACK_STRATEGY=llm_only
