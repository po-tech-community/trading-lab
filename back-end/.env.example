# Server (front-end runs on 3000, back-end on 8000)
PORT=8000
FRONTEND_ORIGIN=http://localhost:3000

# MongoDB (required)
MONGODB_URI=mongodb://localhost:27017/trading-lab

# Redis (optional – set REDIS_ENABLED=true to use Redis; otherwise in-memory cache is used)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL_MS=60000

# JWT (required for auth – login issues token, guard validates it)
# JWT_SECRET signs access tokens (short-lived, 15m).
# JWT_REFRESH_SECRET signs refresh tokens (long-lived, 7d).
# IMPORTANT: these two values MUST be different. Use separate long random strings.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_REFRESH_SECRET=change-me-to-a-different-long-random-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_MAX_AGE=604800000

# Google OAuth (required for L0-BE-11)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/auth/google/callback
FRONTEND_GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# External APIs (for later – Backtest / Level 1+)
# COINGECKO_API_KEY=
# ALPHAVANTAGE_API_KEY=

# AI (for later – Level 4)
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_RATE_LIMIT_MAX=5
AI_RATE_LIMIT_WINDOW_MS=60000

# MCP servers (optional – leave MCP_ENABLED=false to skip; AI will use LLM-only mode)
# Set MCP_ENABLED=true and configure MCP_PROVIDERS to enable evidence-backed AI analysis.
#
# Each provider in MCP_PROVIDERS needs:
#   id:        must match one of: backtest-context | market-snapshot | portfolio-diagnostics
#   name:      human-readable label shown in the UI
#   transport: streamable-http | sse | stdio
#   url:       required for streamable-http and sse transports
#
# Start the MCP servers first: npm run start:mcp (in back-end/)
# Default ports: market=4100  portfolio=4101  backtest-context=4102
MCP_ENABLED=false
MCP_PROVIDERS=[]
# MCP_PROVIDERS=[{"id":"market-snapshot","name":"Market Snapshot","transport":"streamable-http","url":"http://localhost:4100/mcp"},{"id":"portfolio-diagnostics","name":"Portfolio Diagnostics","transport":"streamable-http","url":"http://localhost:4101/mcp"},{"id":"backtest-context","name":"Backtest Context","transport":"streamable-http","url":"http://localhost:4102/mcp"}]
MCP_TIMEOUT_MS=8000
MCP_RETRY_ATTEMPTS=2
MCP_FALLBACK_STRATEGY=llm_only
