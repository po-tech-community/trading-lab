# Server (front-end runs on 3000, back-end on 8000)
PORT=8000

# MongoDB (required)
MONGODB_URI=mongodb://localhost:27017/trading-lab

# Redis (optional – set REDIS_ENABLED=true to use Redis; otherwise in-memory cache is used)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL_MS=60000

# JWT (required for auth stub – login issues token, guard validates it)
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_MAX_AGE=604800000

# Google OAuth (required for L0-BE-11)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/auth/google/callback
FRONTEND_GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# External APIs (for later – Backtest / Level 1+)
# COINGECKO_API_KEY=
# ALPHAVANTAGE_API_KEY=

# AI (for later – Level 4)
# OPENAI_API_KEY=
